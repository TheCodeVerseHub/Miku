# Miku - Environment Configuration
#
# Copy to `.env` and fill in your values.
# NEVER commit `.env` to version control!

# === Discord Bot ===
DISCORD_BOT_TOKEN=your_bot_token_here
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/miku
GITHUB_TOKEN=

# === Web Dashboard ===
DASHBOARD_CLIENT_ID=your_discord_client_id
DASHBOARD_CLIENT_SECRET=your_discord_client_secret
DASHBOARD_REDIRECT_URI=http://localhost:8000/auth/callback
DASHBOARD_SESSION_SECRET=replace-with-32-char-random-string
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8000

# === Docker Compose ===
POSTGRES_USER=miku
POSTGRES_PASSWORD=miku_secret
POSTGRES_DB=miku
