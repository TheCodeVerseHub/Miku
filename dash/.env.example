# NextAuth Configuration
NEXTAUTH_URL=https://your-dashboard-url.vercel.app
NEXTAUTH_SECRET=generate_with_openssl_rand_base64_32

# Discord OAuth2 Credentials
# Get these from https://discord.com/developers/applications
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret

# Discord Bot Token
# Get it from https://discord.com/developers/applications -> Your App -> Bot -> Token
DISCORD_BOT_TOKEN=your_discord_bot_token

# Bot API URL (IMPORTANT FOR PRODUCTION)
# This should be the URL where your bot's API server is hosted
# For local development: http://localhost:8000
# For WispByte or other hosting: https://your-bot-domain.com
BOT_API_URL=https://your-bot-api-url.com
